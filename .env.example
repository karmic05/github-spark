# Throughline — backend secrets. Copy to `.env` for local dev.
# On Lovable Cloud, set these in Cloud → Secrets instead (never in the browser).

# --- HydraDB (the only store for journal entries) ---------------------------
# Get these from app.hydradb.com (or the hackathon HydraDB sponsor channel).
HYDRA_DB_API_KEY=
HYDRA_DB_TENANT_ID=throughline
# Optional override (defaults to https://api.hydradb.com)
# HYDRA_DB_BASE_URL=https://api.hydradb.com

# --- LLM provider (pick ONE; priority is Nebius > Lovable > Anthropic) ------
# 1) Nebius AI Studio (preferred) — OpenAI-compatible. Key from studio.nebius.com.
NEBIUS_API_KEY=
# NEBIUS_MODEL=meta-llama/Llama-3.3-70B-Instruct
# NEBIUS_BASE_URL=https://api.studio.nebius.com/v1/chat/completions

# 2) Lovable AI Gateway — auto-provisioned on Lovable Cloud, nothing to set.
# LOVABLE_API_KEY=
# LOVABLE_AI_MODEL=google/gemini-2.5-flash

# 3) Anthropic — Claude Opus 4.8.
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Seed protection --------------------------------------------------------
# If set, the in-app "Load a demo life" button is disabled and /seed requires
# this token. Leave UNSET to allow seeding from the app during the demo.
# SEED_TOKEN=
